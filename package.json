{
  "name": "jshow-eslint",
  "description": "ESLint for jShow",
  "license": "MIT",
  "homepage": "https://github.com/j-show/eslint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j-show/eslint.git"
  },
  "bugs": {
    "url": "https://github.com/j-show/eslint/issues"
  },
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf ./dist && rm -rf ./packages/**/dist",
    "build": "pnpm clean && pnpm build:rule && pnpm build:config",
    "build:config": "pnpm -F eslint-config-jshow build",
    "build:rule": "pnpm -F eslint-plugin-jshow build",
    "upgrade:config": "node ./scripts/upgrade.mjs -p config",
    "upgrade:rule": "node ./scripts/upgrade.mjs -p rule",
    "release:config": "node ./scripts/publish.mjs -p config && cd packages/config && npm publish",
    "release:rule": "node ./scripts/publish.mjs -p rule && cd packages/rule && npm publish",
    "test": "pnpm test:rule && pnpm test:react && pnpm test:vue",
    "test:rule": "pnpm -F eslint-plugin-jshow test --run",
    "test:react": "cd examples/react && pnpm test",
    "test:vue": "cd examples/vue && pnpm test",
    "preview:react": "cd examples/react && pnpm preview",
    "preview:vue": "cd examples/vue && pnpm preview"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/common-tags": "^1",
    "eslint": "catalog:",
    "eslint-config-jshow": "workspace:*",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-jshow": "workspace:*",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "husky": "latest",
    "lint-staged": "latest",
    "prettier": "catalog:",
    "semver": "^7.7.3",
    "typescript": "catalog:",
    "vite": "^8",
    "vite-plugin-dts": "^5",
    "vitest": "^4",
    "common-tags": "^1",
    "lodash-es": "^4.17.21"
  },
  "pnpm": {
    "overrides": {
      "typescript": "catalog:",
      "typescript-eslint": "catalog:",
      "eslint": "catalog:",
      "eslint-config-jshow": "workspace:*",
      "eslint-config-prettier": "catalog:",
      "eslint-plugin-jshow": "workspace:*",
      "eslint-plugin-prettier": "catalog:",
      "eslint-plugin-react": "catalog:",
      "eslint-plugin-react-hooks": "catalog:",
      "eslint-plugin-vue": "catalog:"
    }
  }
}
