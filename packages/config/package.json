{
  "name": "eslint-config-jshow",
  "version": "1.0.14",
  "description": "ESLint config for jshow",
  "keywords": [
    "eslint",
    "eslint-config",
    "jshow",
    "eslint-config-jshow"
  ],
  "files": [
    "dist",
    "tsconfig.base.json",
    "README.md",
    "README_CN.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./typescript": {
      "types": "./dist/typescript.d.ts",
      "import": "./dist/typescript.mjs",
      "require": "./dist/typescript.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.mjs",
      "require": "./dist/browser.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.cjs"
    },
    "./prettier": {
      "types": "./dist/prettier.d.ts",
      "import": "./dist/prettier.mjs",
      "require": "./dist/prettier.cjs"
    }
  },
  "scripts": {
    "build": "vite build"
  },
  "peerDependencies": {
    "eslint": "catalog:",
    "typescript-eslint": "catalog:",
    "prettier": "catalog:"
  },
  "dependencies": {
    "typescript-eslint": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-jshow": "workspace:*",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "prettier": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "globals": "^17",
    "vue-eslint-parser": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@eslint/js": "catalog:"
  }
}
